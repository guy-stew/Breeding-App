// ============================================================
//  Dog Breeding App — Prisma schema (MVP slice)
// ============================================================
//  Scope: the whelping journey — Breeder, Dog, Litter, Puppy,
//  WeightLog, plus the Mating link that gives a litter its parents.
//  Later entities (HealthRecord, HeatCycle, Buyer, Document,
//  Listing) are sketched as commented stubs at the foot of the
//  file so the shape is reserved without being built yet.
//
//  Two design choices run through every model:
//   1. IDs are UUIDs, generated by the app, so records made
//      offline on different devices never collide on sync.
//   2. Every model carries createdAt / updatedAt / deletedAt
//      so syncing is "send the rows that changed" and deletes
//      are soft (a row is flagged gone, never truly removed —
//      which also means a delete on one device can sync safely).
// ============================================================

generator client {
  // Prisma 7: the new ESM client, generated into your source tree.
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL now lives in prisma.config.ts,
  // NOT here. This block just names the database engine.
}

// ------------------------------------------------------------
//  1. Breeder — the account. Duties attach here, not just dogs.
// ------------------------------------------------------------
model Breeder {
  id          String  @id @default(uuid())
  name        String
  kennelName  String?
  email       String? @unique
  phone       String?

  // UK nation drives which compliance rules apply — see schema doc.
  // Stored now even though the rules engine is a later build.
  ukNation    UkNation @default(england)

  // Licence details — optional at MVP, required before marketplace.
  isLicensed       Boolean  @default(false)
  licenceNumber    String?
  licenceAuthority String?
  licenceExpiry    DateTime?

  // Relations
  dogs    Dog[]
  litters Litter[]

  // Sync housekeeping
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ------------------------------------------------------------
//  2. Dog — the central record. One table for dams, sires AND
//     puppies (a puppy that gets kept simply stays a Dog row).
//     Self-references on sire/dam build the pedigree tree.
// ------------------------------------------------------------
model Dog {
  id        String @id @default(uuid())
  breeder   Breeder @relation(fields: [breederId], references: [id])
  breederId String

  registeredName String?
  callName       String?
  breed          String
  sex            Sex
  colour         String?
  markings       String?
  dateOfBirth    DateTime?
  microchip      String?
  kcRegNumber    String?

  // Pedigree — a dog points to its own sire and dam (both Dogs).
  sire   Dog?    @relation("Sire", fields: [sireId], references: [id])
  sireId String?
  dam    Dog?    @relation("Dam", fields: [damId], references: [id])
  damId  String?
  // The reverse side of those self-relations: a dog's offspring.
  siredLitters Dog[] @relation("Sire")
  boreLitters  Dog[] @relation("Dam")

  ownership Ownership @default(owned)
  status    DogStatus @default(active)

  // Compliance fields — stored now, enforced by the rules engine later.
  caesareanCount Int @default(0)

  // Relations to events
  mathingsAsDam  Mating[] @relation("MatingDam")
  matingsAsSire  Mating[] @relation("MatingSire")
  weightLogs     WeightLog[]
  // If this Dog record IS a puppy in a litter, this links to that role.
  puppyRecord    Puppy?

  // Sync housekeeping
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([breederId])
}

// ------------------------------------------------------------
//  3. Mating — the event linking two dogs. Kept in the MVP only
//     because a Litter needs parents; the eligibility gates that
//     will eventually fire here are a later build.
// ------------------------------------------------------------
model Mating {
  id    String @id @default(uuid())

  dam    Dog    @relation("MatingDam", fields: [damId], references: [id])
  damId  String
  sire   Dog    @relation("MatingSire", fields: [sireId], references: [id])
  sireId String

  matingDate          DateTime?
  method              MatingMethod @default(natural)
  predictedWhelpDate  DateTime?

  litter Litter?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([damId])
  @@index([sireId])
}

// ------------------------------------------------------------
//  4. Litter — the result of a mating. Summary lives here;
//     individual puppies are separate Puppy rows.
// ------------------------------------------------------------
model Litter {
  id        String  @id @default(uuid())
  breeder   Breeder @relation(fields: [breederId], references: [id])
  breederId String

  // A litter usually has a mating, but allow it to be null so a
  // breeder can record a litter fast at 3am and link parents later.
  mating   Mating? @relation(fields: [matingId], references: [id])
  matingId String? @unique

  name       String?      // friendly label, e.g. "Maple's litter"
  whelpDate  DateTime     // drives the 8-week sale gate later
  totalBorn  Int?
  bornAlive  Int?
  notes      String?
  status     LitterStatus @default(whelped)

  puppies Puppy[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([breederId])
}

// ------------------------------------------------------------
//  5. Puppy — a Litter has many. A Puppy IS a Dog (one-to-one to
//     a Dog row) plus litter-specific birth fields. That way a
//     kept puppy's parentage and future records work for free.
// ------------------------------------------------------------
model Puppy {
  id       String @id @default(uuid())
  litter   Litter @relation(fields: [litterId], references: [id])
  litterId String

  // The puppy's own Dog record. Created together with the puppy.
  dog   Dog    @relation(fields: [dogId], references: [id])
  dogId String @unique

  birthOrder      Int?
  collarColour    String?    // identifies look-alike pups — key at whelping
  birthWeightG    Int?       // grams; integers avoid float drift
  sex             Sex
  markings        String?
  palateCheck     Boolean?   // cleft check at birth

  // Compliance fields — stored now, prompts/blocks added later.
  microchip       String?
  microchipDate   DateTime?

  status PuppyStatus @default(available)
  priceP Int?         // price in pence; integer money avoids float drift

  // WeightLogs hang off the Dog record (dogId), not here, so a kept
  // puppy keeps one continuous weight history for life.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([litterId])
}

// ------------------------------------------------------------
//  6. WeightLog — the hero of the MVP. Deliberately minimal.
//     Linked to a Dog (so it follows a kept puppy into adulthood).
// ------------------------------------------------------------
model WeightLog {
  id    String @id @default(uuid())
  dog   Dog    @relation(fields: [dogId], references: [id])
  dogId String

  date    DateTime @default(now())
  weightG Int      // grams as integer — round before save, no float drift
  notes   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([dogId])
  @@index([dogId, date])
}

// ============================================================
//  Enums — the fixed sets of allowed values.
// ============================================================
enum UkNation {
  england
  wales
  scotland
  ni
}

enum Sex {
  dog    // male
  bitch  // female
}

enum Ownership {
  owned
  external
  co_owned
}

enum DogStatus {
  active
  retired
  deceased
}

enum MatingMethod {
  natural
  ai_fresh
  ai_chilled
  ai_frozen
}

enum LitterStatus {
  expecting
  whelped
  weaning
  ready
  all_homed
}

enum PuppyStatus {
  available
  reserved
  sold
  kept
  deceased
}

